# LLM API Configuration
AGENTIC_LLM_PROVIDER=gemini # options: gemini, kimi

# Gemini
AGENTIC_GEMINI_API_KEY=your_gemini_api_key_here

# Kimi (Moonshot)
AGENTIC_KIMI_API_KEY=your_kimi_api_key_here
AGENTIC_KIMI_BASE_URL=https://api.moonshot.cn/v1
AGENTIC_KIMI_MODEL=kimi-k2.5

# Service URLs
AGENTIC_ACRF_URL=http://localhost:18080
AGENTIC_IGW_URL=http://localhost:18081

# Server Port
AGENTIC_AAIHF_PORT=18082

# Testing
AGENTIC_USE_MOCK_AGENT=false
